rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn()        { return request.auth != null; }
    function userId()            { return request.auth.uid; }
    function customerDocPath(cid){ return /databases/$(database)/documents/customers/$(cid); }

    function userProfilePath()   { return /databases/$(database)/documents/userProfiles/$(userId()); }
    function userRole()          { return exists(userProfilePath()) ? get(userProfilePath()).data.role : null; }
    function hasRole(r)          { return isSignedIn() && userRole() == r; }
    function hasAnyRole(list)    { return isSignedIn() && (userRole() in list); }

    function isAdmin()           { return hasRole('admin'); }
    function isManager()         { return hasRole('manager'); }
    function isExecutive()       { return hasRole('executive'); }
    function isProductionHead()  { return hasRole('production_head'); }

    function isValidRole(r)      { return r in ['admin','manager','production_head','executive']; }
    function isNonNegative(n)    { return n is number && n >= 0; }

    function cur()               { return resource.data; }
    function incoming()          { return request.resource.data; }

     // ---------- LMS Helpers ----------
    function lmsUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function lmsUserRole() {
      return exists(lmsUserPath())
        ? get(lmsUserPath()).data.role
        : null;
    }
    function isLmsAdmin() {
      return isSignedIn() && lmsUserRole() == "admin";
    }

    // =========================================================
    // 🔥 LMS / DASHBOARD RULES
    // =========================================================

    // ---------- Courses ----------
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isLmsAdmin();
    }

   // ---------- Enrollments ----------
match /enrollments/{enrollmentId} {
  allow read: if isSignedIn()
    && enrollmentId.startsWith(userId());
  allow create, update: if isSignedIn()
    && enrollmentId.startsWith(userId());
  allow delete: if isLmsAdmin();
}

    // ---------- Progress ----------
    match /progress/{progressId} {
      allow read, write: if isSignedIn()
        && progressId.startsWith(userId());
    }

    // ---------- Masterclass ----------
    match /masterclass/{doc}/users/{uid} {
      allow read, write: if isSignedIn() && uid == request.auth.uid;
      allow read, write: if isLmsAdmin();
    }

	  // ---------- Audit Logs ----------
    match /auditLogs/{logId} {
      allow read: if hasAnyRole(['admin', 'manager']);
      allow create: if isSignedIn();
    }


    // =========================================================
    // 🔒 EXISTING RULES (UNCHANGED BELOW)
    // =========================================================

    // ---------- User Profiles (ERP Staff) ----------
    match /userProfiles/{uid} {
      // 🔴 TEMPORARY - Allow ALL reads and writes for testing
      allow read, write: if true;

      allow read: if isSignedIn() && (userId() == uid || isAdmin());
      allow create, update: if (isAdmin() || isManager()) && profileValid();
      allow delete: if isAdmin();
      allow update: if isSignedIn()
        && userId() == uid
        && !isAdmin()
        && userSelfUpdateValid();

      function profileValid() {
        return incoming().keys().hasOnly(['name','email','role','monthlySalary','createdAt'])
          && incoming().name is string
          && incoming().email is string
          && isValidRole(incoming().role)
          && (incoming().monthlySalary is number)
          && isNonNegative(incoming().monthlySalary);
      }

      function userSelfUpdateValid() {
        return incoming().keys().hasOnly(['name'])
          && incoming().name is string;
      }
    }

    // ---------- Contact Form Submissions ----------
    match /contactSubmissions/{document} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && hasAnyRole(['admin', 'manager', 'executive']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && hasAnyRole(['admin', 'manager', 'executive']);
        allow create: if true;
        allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
      }
    }

  // ---------- Users (LMS) ----------
match /users/{uid} {
  allow read: if isSignedIn();
  allow update: if isSignedIn() && uid == request.auth.uid;
  allow write: if isLmsAdmin();
}

    // ---------- Customers ----------
    match /customers/{customerId} {
      allow read: if isSignedIn()
        && (customerId == userId() || resource.data.authUid == userId());
      allow create: if isSignedIn()
        && customerId == userId()
        && incoming().authUid == userId();
      allow update: if isSignedIn()
        && (customerId == userId() || resource.data.authUid == userId());
      allow read, create, update: if isSignedIn() && hasAnyRole(['admin','manager']);
      allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
    }

    // ---------- Materials ----------
    match /materials/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && incoming().createdBy == userId();
      allow update, delete: if isSignedIn()
        && (isAdmin() || isManager() || cur().createdBy == userId());

      match /batches/{batchId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (isAdmin() || isManager() || cur().createdBy == userId());
        allow update, delete: if false;
      }

      match /logs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (isAdmin() || isManager() || cur().createdBy == userId());
        allow update, delete: if false;
      }
    }

    // ---------- Products ----------
    match /products/{id} {
      allow read: if resource.data.showInOnlineStore == true || isSignedIn();
      allow create: if isSignedIn() && incoming().createdBy == userId();
      allow update: if isSignedIn() && (
        isAdmin() || isManager() || isExecutive() || isProductionHead()
        || cur().createdBy == userId()
      );
      allow update: if isSignedIn() && (
        // Staff can update fully
        (isAdmin() || isManager() || isExecutive() || isProductionHead() || cur().createdBy == userId())
        ||
        // Customers can ONLY reduce stock (during checkout)
        (request.resource.data.fgQuantity <= resource.data.fgQuantity &&
         request.resource.data.fgQuantity >= 0)
      );

      function customerStockUpdateValid() {
        let changed = request.resource.data.diff(resource.data).changedKeys();
        return changed.hasOnly(['fgQuantity', 'updatedAt'])
          && request.resource.data.fgQuantity is number
          && request.resource.data.fgQuantity >= 0
          && request.resource.data.fgQuantity <= resource.data.fgQuantity;
      }

      allow delete: if isSignedIn()
        && (isAdmin() || isManager() || cur().createdBy == userId());

      match /logs/{logId} {
        allow read, create: if isSignedIn()
          && (isAdmin() || isManager() || isExecutive() || isProductionHead()
              || cur().createdBy == userId());
        allow update, delete: if false;
      }
    }

    // ---------- Orders ----------
    match /orders/{id} {
      // Allow users to read their own orders
      allow read: if isSignedIn() && (
        resource.data.userId == userId()
        || resource.data.customerId == userId()
        || resource.data.billingAddress.email == request.auth.token.email
        || resource.data.shippingAddress.email == request.auth.token.email
        || (resource.data.customerId != null
            && exists(customerDocPath(resource.data.customerId))
            && get(customerDocPath(resource.data.customerId)).data.authUid == userId())
      );
      // Staff can read all orders
      allow read: if isSignedIn() && hasAnyRole(['admin','manager','executive','production_head']);
      // Admin can create orders
      allow create: if isSignedIn();
      // Staff can update orders
      allow update: if isSignedIn() && hasAnyRole(['admin','manager','executive','production_head']);
      // Only admin/managers can delete
      allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
    }

    // ---------- Wishlist ----------
    match /wishlist/{wishlistId} {
      allow create: if isSignedIn() && incoming().userId == userId();
      allow read, update, delete: if isSignedIn() && resource.data.userId == userId();
    }

    // ---------- Staff ----------
    match /staff/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isManager();
    }

    // ---------- Staff Messages ----------
    match /staffMessages/{messageId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderId == userId();
      allow update: if isSignedIn() && resource.data.receiverId == userId();
      allow delete: if isSignedIn() && resource.data.senderId == userId();
    }

    // ---------- Work Orders ----------
    match /workOrders/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && hasAnyRole(['admin','manager','executive','production_head']);
      allow delete: if isAdmin() || isManager();

      match /comments/{commentId} {
        allow read, create, update: if isSignedIn();
        allow delete: if false;
      }

      match /pendingLogs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().submittedBy == userId();
        allow update, delete: if isSignedIn() && (isAdmin() || isManager());
      }

      match /rejectedLogs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isAdmin() || isManager());
        // Allow admins and managers to delete
        allow update, delete: if isSignedIn() && (isAdmin() || isManager());
      }
    }

    // ---------- Material Requests ----------
    match /materialRequests/{id} {
      allow read, create: if isSignedIn();
      allow update: if hasAnyRole(['admin','manager','production_head','executive']);
      allow delete: if isAdmin() || isManager();
    }

    // ---------- Counters ----------
    match /counters/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ---------- Certificates ----------
    match /certificates/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if hasAnyRole(['admin','manager','production_head']);
    }

    // ---------- Contacts ----------
    match /contacts/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if hasAnyRole(['admin','manager','production_head']);
    }

    // ---------- Delivery & App Settings ----------
    match /settings/{document=**} {
      allow read, write: if isSignedIn() && (isAdmin() || isManager());
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }

  }
}