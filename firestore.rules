rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn()        { return request.auth != null; }
    function userId()            { return request.auth.uid; }
    function customerDocPath(cid){ return /databases/$(database)/documents/customers/$(cid); }

    function userProfilePath()   { return /databases/$(database)/documents/userProfiles/$(userId()); }
    function userRole()          { return exists(userProfilePath()) ? get(userProfilePath()).data.role : null; }
    function hasRole(r)          { return isSignedIn() && userRole() == r; }
    function hasAnyRole(list)    { return isSignedIn() && (userRole() in list); }

    function isAdmin()           { return hasRole('admin'); }
    function isManager()         { return hasRole('manager'); }
    function isExecutive()       { return hasRole('executive'); }
    function isProductionHead()  { return hasRole('production_head'); }

    function isValidRole(r)      { return r in ['admin','manager','production_head','executive']; }
    function isNonNegative(n)    { return n is number && n >= 0; }

    function cur()               { return resource.data; }
    function incoming()          { return request.resource.data; }

    // ---------- Shopify webhook ----------
    function isShopifyWebhook() {
      return request.auth == null
        && request.get('X-Shopify-Hmac-Sha256') != null;
    }

    // ---------- User Profiles (ERP Staff) ----------
    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (userId() == uid || isAdmin());

      allow create, update: if (isAdmin() || isManager()) && profileValid();
      allow delete: if isAdmin();

      allow update: if isSignedIn()
        && userId() == uid
        && !isAdmin()
        && userSelfUpdateValid();

      function profileValid() {
        return incoming().keys().hasOnly(['name','email','role','monthlySalary','createdAt'])
          && incoming().name is string
          && incoming().email is string
          && isValidRole(incoming().role)
          && (incoming().monthlySalary is number)
          && isNonNegative(incoming().monthlySalary);
      }

      function userSelfUpdateValid() {
        return incoming().keys().hasOnly(['name'])
          && incoming().name is string;
      }
    }
    
    // ---------- Contact Form Submissions ----------
match /contactSubmissions/{document} {
  // Allow anyone to submit contact form (no authentication required)
  allow create: if true;
  
  // Only authenticated staff can read/update/delete contact submissions
  allow read, update, delete: if isSignedIn() && hasAnyRole(['admin', 'manager', 'executive']);
  
  // Subcollection for WhatsApp message tracking
  match /messages/{messageId} {
    allow read: if isSignedIn() && hasAnyRole(['admin', 'manager', 'executive']);
    allow create: if true;  // Allow creating WhatsApp message records
    allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
  }
}

    // ---------- Users (Online Store Customers) - DEPRECATED ----------
    // Keeping for backward compatibility during migration
    match /users/{userId} {
      // Customers can read/write their own profile
      allow read, write: if isSignedIn() && userId() == request.auth.uid;
      // ERP admins can read all customer profiles
      allow read: if isSignedIn() && isAdmin();
    }

    // ---------- Customers (Online Store + Admin Created) ----------
    match /customers/{customerId} {
      // Customers can read their own profile:
      // - Self-created customer doc: docId == auth.uid
      // - Admin-created customer doc: resource.data.authUid == auth.uid (linked after login)
      allow read: if isSignedIn()
        && (customerId == userId() || resource.data.authUid == userId());

      // Customers can create their own profile doc at /customers/{auth.uid}
      allow create: if isSignedIn()
        && customerId == userId()
        && incoming().authUid == userId();

      // Customers can update their own profile (either docId == uid OR linked authUid == uid)
      // Keep this permissive to avoid breaking UI; validations can be tightened later.
      allow update: if isSignedIn()
        && (customerId == userId() || resource.data.authUid == userId());

      // ERP Admins can read/create/update all customers
      allow read, create, update: if isSignedIn() && isAdmin();

     allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
    }

    // ---------- Materials ----------
    match /materials/{id} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && incoming().createdBy == userId();

      allow update, delete: if isSignedIn()
        && (isAdmin() || cur().createdBy == userId());

      match /batches/{batchId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (isAdmin() || cur().createdBy == userId());
        allow update, delete: if false;
      }

      match /logs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (isAdmin() || cur().createdBy == userId());
        allow update, delete: if false;
      }
    }

    // ---------- Products ----------
    match /products/{id} {

      // ✅ PUBLIC READ FOR ONLINE STORE (only if showInOnlineStore is true)
      allow read: if resource.data.showInOnlineStore == true || isSignedIn();

      // ERP / Shopify create
      allow create: if
        (isSignedIn() && incoming().createdBy == userId())
        || isShopifyWebhook();

      // ERP update (admin, manager, executive, production_head, or creator)
      allow update: if
        (isSignedIn() && (isAdmin() || isManager() || isExecutive() || isProductionHead() || cur().createdBy == userId()))
        || isShopifyWebhook();

      // ✅ ONLINE STORE: Allow customers to update stock during order placement
      // Only allow updating fgQuantity and updatedAt fields
      // Stock can only be reduced (not increased) - prevents stock manipulation
      allow update: if isSignedIn() 
        && customerStockUpdateValid();

      function customerStockUpdateValid() {
        // IMPORTANT: request.resource.data contains the FULL document after update,
        // so we must validate only the CHANGED keys (diff), not all keys().
        let changed = request.resource.data.diff(resource.data).changedKeys();

        return changed.hasOnly(['fgQuantity', 'updatedAt'])
          // fgQuantity must be a number
          && request.resource.data.fgQuantity is number
          // Stock must be non-negative
          && request.resource.data.fgQuantity >= 0
          // Stock can only be reduced (prevent stock manipulation)
          && request.resource.data.fgQuantity <= resource.data.fgQuantity;
      }

      // ERP delete
      allow delete: if isSignedIn()
        && (isAdmin() || cur().createdBy == userId());

      // Product logs
      match /logs/{logId} {
        allow read, create: if isSignedIn()
          && (isAdmin() || isManager() || isExecutive() || isProductionHead() || cur().createdBy == userId());
        allow update, delete: if false;
      }
    }

    // ---------- Orders (ONLINE STORE + ERP) ----------
    match /orders/{id} {

      // ✅ ONLINE STORE: Customers can create orders if:
      // - userId == auth.uid (backward compatibility)
      // - customerId == auth.uid (self-created customer)
      // - OR customerId points to a /customers/{customerId} doc linked via authUid == auth.uid
      allow create: if isSignedIn()
        && (
          incoming().userId == userId()
          || incoming().customerId == userId()
          || (incoming().customerId != null
              && exists(customerDocPath(incoming().customerId))
              && get(customerDocPath(incoming().customerId)).data.authUid == userId())
        );

      // ✅ ONLINE STORE: Customers can read their orders if:
      // - userId == auth.uid (backward compatibility)
      // - customerId == auth.uid (self-created customer)
      // - OR order.customerId points to a /customers doc linked via authUid == auth.uid
      allow read: if isSignedIn()
        && (
          resource.data.userId == userId()
          || resource.data.customerId == userId()
          || (resource.data.customerId != null
              && exists(customerDocPath(resource.data.customerId))
              && get(customerDocPath(resource.data.customerId)).data.authUid == userId())
        );

      // ✅ ERP: Staff can read/update all orders
      allow read, update: if isSignedIn() && hasAnyRole(['admin','manager','executive','production_head']);

      // ✅ ERP: Admins can create orders for any customer
      allow create: if isSignedIn() && isAdmin();

      allow delete: if isSignedIn() && hasAnyRole(['admin', 'manager']);
    }

    // ---------- Wishlist (Online Store) ----------
    match /wishlist/{wishlistId} {
      // Customers can create wishlist items (must be their own)
      allow create: if isSignedIn() && incoming().userId == userId();

      // Customers can read/update/delete their own wishlist items
      allow read, update, delete: if isSignedIn() && resource.data.userId == userId();
    }

   // ---------- Staff ----------
match /staff/{uid} {
  allow read: if isSignedIn();
  allow create, update: if isAdmin();
  allow delete: if isAdmin();
}

// ---------- Staff Messages ----------
match /staffMessages/{messageId} {
  allow read, list: if isSignedIn();
  
  allow create: if isSignedIn() && 
    incoming().senderId == userId();
  
  allow update: if isSignedIn() && 
    resource.data.receiverId == userId();
  
  allow delete: if isSignedIn() && 
    resource.data.senderId == userId();
}

    // ---------- Work Orders ----------
    match /workOrders/{id} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
        && hasAnyRole(['admin','manager','executive','production_head']);

      allow delete: if isAdmin();

      // Work order comments (discussion)
      match /comments/{commentId} {
        // Any signed-in ERP user can read the discussion
        allow read: if isSignedIn();

        // Any signed-in user can add a comment
        allow create: if isSignedIn();

        // Allow marking comments as read or editing own comments
        allow update: if isSignedIn();

        // No deletes for now to keep audit trail
        allow delete: if false;
      }

      match /pendingLogs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().submittedBy == userId();
        allow update, delete: if isSignedIn() && (isAdmin() || isManager());
      }

      match /rejectedLogs/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isAdmin() || isManager());
        allow update, delete: if false;
      }
    }

    // ---------- Material Requests ----------
    match /materialRequests/{id} {
      allow read, create: if isSignedIn();
      allow update: if hasAnyRole(['admin','manager','production_head']);
      allow delete: if isAdmin();
    }

    // ---------- Counters ----------
    match /counters/{docId} {
      allow read: if isSignedIn();
      allow create, update: if hasAnyRole(['admin','manager','production_head']);
      allow delete: if false;
    }

    // ---------- Certificates ----------
    match /certificates/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if hasAnyRole(['admin','manager','production_head']);
    }

    // ---------- Contacts ----------
    match /contacts/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if hasAnyRole(['admin','manager','production_head']);
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
